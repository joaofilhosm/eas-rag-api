# ========================================
# EAS - API RAG Base de Conhecimento
# ========================================

# ========================================
# PostgreSQL + pgvector
# ========================================
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=eas_rag
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/eas_rag

# ========================================
# OpenRouter (LLM Provider)
# ========================================
OPENROUTER_API_KEY=sk-or-xxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=openai/gpt-4o-mini
FALLBACK_MODEL=anthropic/claude-3.5-sonnet

# ========================================
# API Security
# ========================================
API_MASTER_KEY=sua-chave-master-aqui
API_KEY_EXPIRATION_DAYS=365

# ========================================
# Scraper
# ========================================
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
SCRAPER_DELAY_SECONDS=2
SCRAPER_MAX_RETRIES=3

# ========================================
# Embeddings
# ========================================
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ========================================
# Server
# ========================================
HOST=0.0.0.0
PORT=8000
API_PORT=8000
DEBUG=true

# ========================================
# Docker Ports (para docker-compose)
# ========================================
# DB_PORT=5432         # Porta externa do PostgreSQL
# API_PORT=8000        # Porta externa da API
# ADMINER_PORT=8080    # Porta do Adminer (opcional)